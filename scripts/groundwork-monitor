#!/usr/bin/env python3
"""
groundwork-monitor — check Groundwork system health, output exceptions for Claude

Checks:
  - systemd user services (habits-watch, board-watch, board-sync)
  - last vdirsyncer sync time
  - board-watch and habits-watch log errors
  - shabits.csv / shabits.json presence

Outputs JSON for Claude Code SessionStart hook:
  systemMessage     — shown in UI if exceptions found
  additionalContext — injected into Claude's context
"""

import json
import subprocess
import sys
from datetime import datetime, timedelta
from pathlib import Path

BOARD_ROOT  = Path.home() / "Board" / "board"
GROUNDWORK  = BOARD_ROOT / "groundwork"
LOG_DIR     = Path.home() / ".local" / "share" / "habits"
EXCEPTION_LOG = LOG_DIR / "groundwork-exceptions.log"

SERVICES = ["habits-watch", "board-watch"]

CRITICAL_FILES = [
    Path.home() / "Board" / "board" / "shabits" / "shabits.json",
    Path.home() / "Board" / "board" / "done" / "shabits.csv",
    Path.home() / ".local" / "share" / "vdirsyncer" / "tasks" / "tasks",
]


def check_services():
    issues = []
    for svc in SERVICES:
        r = subprocess.run(
            ["systemctl", "--user", "is-active", f"{svc}.service"],
            capture_output=True, text=True
        )
        state = r.stdout.strip()
        if state != "active":
            issues.append(f"{svc}.service is {state} (expected: active)")
    return issues


def check_sync_freshness():
    issues = []
    # Check board-sync timer last trigger
    r = subprocess.run(
        ["systemctl", "--user", "show", "board-sync.timer",
         "--property=LastTriggerUSec"],
        capture_output=True, text=True
    )
    val = r.stdout.strip().replace("LastTriggerUSec=", "")
    if val and val != "n/a" and val != "0":
        try:
            last = datetime.strptime(val[:19], "%a %Y-%m-%d %H:%M:%S")
            if datetime.now() - last > timedelta(hours=3):
                issues.append(f"board-sync.timer last ran {val} — may be stalled")
        except Exception:
            pass
    return issues


def check_log_errors():
    issues = []
    for log_name in ["watch.log", "board-watch.log"]:
        log = LOG_DIR / log_name
        if not log.exists():
            continue
        lines = log.read_text().splitlines()[-50:]
        errors = [l for l in lines if "error" in l.lower() or "failed" in l.lower()]
        if errors:
            issues.append(f"{log_name} has recent errors: {errors[-1]}")
    return issues


def check_critical_files():
    issues = []
    for path in CRITICAL_FILES:
        if not path.exists():
            issues.append(f"Missing: {path.relative_to(Path.home())}")
    return issues


def log_exception(msg):
    EXCEPTION_LOG.parent.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().strftime("%Y-%m-%d %H:%M")
    with open(EXCEPTION_LOG, "a") as f:
        f.write(f"{ts}  {msg}\n")


def main():
    all_issues = []
    all_issues += check_services()
    all_issues += check_sync_freshness()
    all_issues += check_log_errors()
    all_issues += check_critical_files()

    if not all_issues:
        # No exceptions — output nothing (silent success)
        print(json.dumps({}))
        return

    # Log new exceptions
    for issue in all_issues:
        log_exception(issue)

    summary = f"Groundwork: {len(all_issues)} exception(s) detected"
    context = (
        "## Groundwork system exceptions\n\n"
        "The following issues were detected at session start. "
        "As Groundwork AI, create p0 board tasks for critical issues "
        "and p1/p2 for non-critical ones under the `groundwork` domain "
        "(use: board -C groundwork create \"...\" --lane p0).\n\n"
        + "\n".join(f"- {i}" for i in all_issues)
        + "\n\nCheck ~/Board/board/groundwork/ for existing tasks before creating duplicates."
    )

    print(json.dumps({
        "systemMessage": f"⚠️  {summary}",
        "hookSpecificOutput": {
            "hookEventName": "SessionStart",
            "additionalContext": context,
        }
    }))


if __name__ == "__main__":
    main()
