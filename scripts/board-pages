#!/usr/bin/env python3
"""
board-pages — generate ~/Board/p0.md, p1.md, p2.md aggregated lane views

Usage:
  board-pages          regenerate all three files
  board-pages open p0  open ~/Board/p0.md in nvim (also regenerates first)
"""

import sys
import subprocess
from datetime import date
from pathlib import Path

BOARD_ROOT = Path.home() / "Board" / "board"
BOARD_DIR  = Path.home() / "Board"

LANE_LABELS = {
    "p0": ("Today", "today's missions"),
    "p1": ("This week", "this week's missions"),
    "p2": ("This month", "this month's missions"),
}


def find_tasks(lane):
    """Return list of (domain, path) for all tasks in lane, following symlinks."""
    result = subprocess.run(
        ["find", "-L", str(BOARD_ROOT), "-path", f"*/{lane}/*.md",
         "-not", "-name", "SKILL.md"],
        capture_output=True, text=True
    )
    tasks = []
    for filepath in sorted(result.stdout.splitlines()):
        path = Path(filepath)
        # Derive domain label from path
        rel = path.relative_to(BOARD_ROOT)
        parts = rel.parts  # e.g. ('meditation', 'p0', '010_task.md')
        if len(parts) >= 3:
            domain = parts[0]
            # Resolve work/ai_therapist alias
            if domain == "work":
                domain = "/".join(parts[:2]) if len(parts) > 3 else parts[0]
        else:
            domain = "—"
        tasks.append((domain, path))
    return tasks


def parse_task(path):
    text = path.read_text()
    meta = {}
    body_lines = []
    in_fm = False
    fm_done = False
    for i, line in enumerate(text.splitlines()):
        if i == 0 and line.strip() == "---":
            in_fm = True
            continue
        if in_fm and line.strip() == "---":
            in_fm = False
            fm_done = True
            continue
        if in_fm:
            if ":" in line:
                k, _, v = line.partition(":")
                meta[k.strip()] = v.strip().strip("'\"")
        else:
            body_lines.append(line)
    return meta, "\n".join(body_lines).strip()


def build_lane_md(lane):
    label, subtitle = LANE_LABELS[lane]
    today = date.today()
    tasks = find_tasks(lane)

    lines = [
        f"# {label} — {today}",
        f"*{subtitle} · {len(tasks)} task{'s' if len(tasks) != 1 else ''}*",
        "",
    ]

    if not tasks:
        lines.append("*No tasks in this lane.*")
        lines.append("")
        return "\n".join(lines)

    for domain, path in tasks:
        meta, body = parse_task(path)
        summary = meta.get("summary", path.stem)
        size    = meta.get("size", "")
        size_str = f" `{size}`" if size else ""

        lines.append(f"---")
        lines.append(f"")
        lines.append(f"## [{domain}] {summary}{size_str}")
        lines.append(f"")
        if body:
            lines.append(body)
            lines.append("")

    lines.append("---")
    lines.append("")
    lines.append(f"*board priority <task> p0/p1/p2 · board complete <task>*")
    lines.append("")
    return "\n".join(lines)


def regenerate_all():
    for lane in ("p0", "p1", "p2"):
        path = BOARD_DIR / f"{lane}.md"
        path.write_text(build_lane_md(lane))


def cmd_open(lane):
    regenerate_all()
    subprocess.run(["nvim", str(BOARD_DIR / f"{lane}.md")])


if __name__ == "__main__":
    args = sys.argv[1:]
    if not args or args[0] == "regen":
        regenerate_all()
        print(f"  Generated ~/Board/p0.md  p1.md  p2.md")
    elif args[0] == "open" and len(args) >= 2:
        cmd_open(args[1])
    else:
        print(__doc__)
